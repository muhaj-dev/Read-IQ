# readIQ — BTL Runtime credentials
# Copy this file to ".env" and fill in your scoped hackathon values.
# The .env file is git-ignored and must NEVER be committed.
# These vars are read ONLY in src/lib/btl.ts.

# Scoped BTL Runtime API key (issued for the hackathon)
EXPO_PUBLIC_BTL_API_KEY=

# BTL Runtime base URL, e.g. https://api.badtheorylabs.com/v1
EXPO_PUBLIC_BTL_BASE_URL=

# --- Record transcription (Whisper STT) ------------------------------------
# BTL cannot transcribe audio (the gateway strips audio input), so lecture Record
# uses a Whisper-compatible API directly (read ONLY in src/lib/transcription.ts).
# Everything after transcription — summary, quiz, podcast, Ask — still runs on BTL.
# Leave the key blank to disable auto-transcribe; Record then falls back to a
# manual, editable transcript.
#
# RECOMMENDED — Groq (free tier). Just add this ONE line (base URL + model default
# to Groq's free Whisper automatically):
#   EXPO_PUBLIC_GROQ_API_KEY=gsk_...
# Get the key free at https://console.groq.com/keys (sign in → API Keys → Create).
EXPO_PUBLIC_GROQ_API_KEY=

# Optional overrides (only if you don't use Groq's defaults):
#   EXPO_PUBLIC_STT_BASE_URL=https://api.groq.com/openai/v1
#   EXPO_PUBLIC_STT_MODEL=whisper-large-v3        # max accuracy (slower than turbo)
#
# Already have an OpenAI key instead? Set this and it uses api.openai.com + whisper-1:
#   EXPO_PUBLIC_OPENAI_API_KEY=sk-...
